rules_version = '2';

/* ============================================================
   BIZEN HT — Règles de sécurité Firestore
   But : aucune fuite de données, aucune écriture non autorisée.
   À déployer dans : Firebase Console > Firestore Database > Règles
   (voir SECURITE-DEPLOIEMENT.md)
   ============================================================ */

service cloud.firestore {
  match /databases/{database}/documents {

    /* L'administrateur (toi) est identifié par son e-mail unique. */
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "bizenht@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    /* -------- PROFIL PRIVÉ (users) : le propriétaire uniquement --------
       Contient e-mail, téléphone, date de naissance => JAMAIS public. */
    match /users/{userId} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    /* -------- PROFIL PUBLIC (publicProfiles) : catalogue --------
       Pas d'e-mail/téléphone ici. Lecture publique (catalogue + QR).
       Écriture seulement par le propriétaire ou l'admin. */
    match /publicProfiles/{userId} {
      allow read:  if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    /* -------- RÉSERVATIONS : client + Elu concernés + admin --------
       userId = client, prestateId = Elu. Personne d'autre ne peut lire. */
    match /reservations/{resId} {
      allow read:   if isAdmin()
        || (isSignedIn() && (resource.data.userId == request.auth.uid
                          || resource.data.prestateId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && (resource.data.userId == request.auth.uid
                          || resource.data.prestateId == request.auth.uid));
      allow delete: if isAdmin();
    }

    /* -------- PAIEMENTS : le propriétaire + admin uniquement -------- */
    match /payments/{payId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    /* -------- NOTES / ÉTOILES (ratings) : lecture publique --------
       Servent à calculer la moyenne affichée sur le catalogue.
       Créables par un utilisateur connecté ; non modifiables ensuite. */
    match /ratings/{ratingId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /* -------- AVIS GLOBAUX DU SITE (siteReviews) --------
       Public : ne voit QUE les avis approuvés.
       Un utilisateur connecté peut en créer un, forcément "pending"
       (il ne peut pas s'auto-approuver). Seul l'admin approuve/supprime. */
    match /siteReviews/{reviewId} {
      allow read: if isAdmin()
        || (resource != null && resource.data.status == "approved");
      allow create: if isSignedIn()
        && request.resource.data.status == "pending"
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 80
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    /* -------- NOTIFICATIONS ADMIN (adminNotifs) — optionnel --------
       Réservé à l'admin. */
    match /adminNotifs/{notifId} {
      allow read, write: if isAdmin();
    }

    /* -------- HOTELS PARTENAIRES (hotels) --------
       Gérés manuellement par l'admin. Lecture publique : la page de
       réservation affiche la liste des hôtels de la zone choisie. */
    match /hotels/{hotelId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    /* -------- MESSAGERIE DE DÉCOUVERTE (DM avant réservation) --------
       Threads + messages. L'ÉCRITURE passe UNIQUEMENT par la fonction
       Netlify dm-send (Admin SDK) => anti-triche sur les limites + filtrage.
       Le client ne fait que LIRE ses propres fils/messages. */
    match /dmThreads/{threadId} {
      /* Lecture alignée sur les champs filtrables (requêtes par userUid / eluUid) */
      allow read:   if isAdmin()
        || (isSignedIn() && (resource.data.userUid == request.auth.uid
                          || resource.data.eluUid == request.auth.uid));
      allow create, delete: if isAdmin();   /* créé par la fonction (Admin SDK) */
      /* Un participant peut SEULEMENT remettre à zéro ses compteurs de non-lus. */
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.participants
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadForElu', 'unreadForUser']));
    }
    match /dmMessages/{msgId} {
      /* Lu via une requête where("participants","array-contains",uid) => rule-safe */
      allow read:  if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      allow write: if isAdmin();   /* écrit par la fonction (Admin SDK) */
    }
    /* Compteurs journaliers : strictement serveur (anti-triche). */
    match /dmCounters/{counterId} {
      allow read, write: if isAdmin();
    }

    /* -------- LISTE D'ATTENTE DIASPORA (diasporaWaitlist) --------
       N'importe quel visiteur (même non connecté) peut s'inscrire avec
       son pays + WhatsApp. Lecture/gestion réservées à l'admin. */
    match /diasporaWaitlist/{entryId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.country is string
        && request.resource.data.country.size() > 0
        && request.resource.data.country.size() <= 80
        && request.resource.data.whatsapp is string
        && request.resource.data.whatsapp.size() > 0
        && request.resource.data.whatsapp.size() <= 40
        && request.resource.data.status == "new";
    }

    /* -------- CHAT SÉCURISÉ : seulement les 2 participants -------- */
    match /chats/{resId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.participants);

      match /messages/{msgId} {
        allow read, create, update, delete: if isAdmin()
          || (isSignedIn() && request.auth.uid in
              get(/databases/$(database)/documents/chats/$(resId)).data.participants);
      }
    }

    /* -------- AFFILIATION : codes promo --------
       Créés manuellement par l'admin. Le propriétaire lit SON code (par e-mail). */
    match /promoCodes/{codeId} {
      allow read:  if isAdmin()
        || (isSignedIn() && resource.data.ownerEmail == request.auth.token.email);
      allow write: if isAdmin();
    }

    /* -------- AFFILIATION : transactions (commissions gagnées) --------
       Écrites par l'admin à la confirmation du paiement. L'affilié lit les siennes. */
    match /affiliateTransactions/{txId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.ownerEmail == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    /* -------- AFFILIATION : demandes de retrait --------
       L'affilié crée sa demande (à son nom, statut "pending"). Admin traite. */
    match /affiliateWithdrawals/{wId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.ownerEmail == request.auth.token.email);
      allow create: if isSignedIn()
        && request.resource.data.ownerEmail == request.auth.token.email
        && request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    /* -------- TOUT LE RESTE : interdit par défaut --------
       (Aucune collection oubliée ne reste ouverte.) */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
