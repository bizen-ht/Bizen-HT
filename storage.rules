rules_version = '2';

/* ============================================================
   BIZEN HT — Règles de sécurité Firebase Storage (médias)
   But : seul le propriétaire (ou l'admin) peut téléverser dans
   son dossier ; uniquement des images/vidéos ; taille limitée.
   À déployer dans : Firebase Console > Storage > Règles
   ============================================================ */

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "bizenht@gmail.com";
    }

    /* Upload autorisé seulement si : c'est le propriétaire du dossier,
       le fichier est une image ou une vidéo, et fait moins de 60 Mo. */
    function isValidOwnerUpload(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 60 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    /* Lecture publique : les photos s'affichent dans le catalogue. */
    match /{allPaths=**} {
      allow read: if true;
    }

    /* Médias des Elu : Elu/{uid}/... */
    match /Elu/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isValidOwnerUpload(userId);
    }

    /* Médias des groupes Krey : krey/{uid}/... */
    match /krey/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isValidOwnerUpload(userId);
    }

    /* Médias envoyés dans la messagerie (client -> Elu) : dm/{uid}/... */
    match /dm/{userId}/{allPaths=**} {
      allow write: if isAdmin() || isValidOwnerUpload(userId);
    }

    /* Tout autre chemin : écriture admin uniquement (lecture déjà publique). */
    match /{root}/{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}
